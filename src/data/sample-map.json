  "cities": [
    {
      "id": "imag-cap", "countryId": "imaginatio", "rank": "capital",
      "label": "Why-We-Build", "labelJa": "なぜ作るか", "position": [780, 380], "urbanDensity": 6,
      "summary": "The reason this exists: existing AI chat UIs are linear and lossy. Past conversations vanish into scrollback. Atlas treats them as terrain so the human spatial-memory system can find them again.",
      "messages": [
        { "role": "user", "text": "ChatGPTで議論したあの戦略の話、3ヶ月前なんだけど、どこにあったか思い出せない" },
        { "role": "assistant", "text": "それが現状のチャットUIの構造的欠点です。線形のメッセージリストは時系列にしか並べられず、複数セッションをまたいだ思考のつながりは検索クエリでしか辿れません。" },
        { "role": "user", "text": "じゃあどう解決するか。地図にしたい。地形メタファーで。" },
        { "role": "assistant", "text": "人間は文字列より空間を覚えます。会話を国・街・道路として配置すれば「あの山の向こうのあたり」で見つけられる。" }
      ]
    },
    { "id": "imag-c1",  "countryId": "imaginatio",   "rank": "city",    "label": "Differentiation",                          "position": [730, 220], "urbanDensity": 4 },
    {
      "id": "imag-t1", "countryId": "imaginatio", "rank": "town",
      "label": "Terrain metaphor", "position": [920, 110], "urbanDensity": 1,
      "summary": "Why a literal map and not just a graph. Network diagrams already exist (ChatGPT-2D, Heptabase) — terrain is the unclaimed metaphor, and it carries the spatial cue the brain actually uses.",
      "messages": [
        { "role": "user", "text": "ネットワーク図にすると既存のものと差別化できない。地形にすると何が違う?" },
        { "role": "assistant", "text": "国・山・河川は階層と隔たりを同時に表現できます。ノード+エッジの平面グラフでは表現できない情報量です。" }
      ]
    },

    {
      "id": "arch-cap", "countryId": "architectura", "rank": "capital",
      "label": "Stack", "labelJa": "技術選定", "position": [1100, 430], "urbanDensity": 9,
      "summary": "The technology choices: Next.js 16 + Postgres + Prisma 7 + Auth.js v5 + Anthropic SDK. Picked for self-hostability (Docker compose) and BYOK economics (the user pays for their own LLM calls).",
      "messages": [
        { "role": "user", "text": "Hono on Workers と Next.js どっちがいい?" },
        { "role": "assistant", "text": "Next.js を推奨します。Server Components で地図 SSR、認証ライブラリの選択肢、Vercel デプロイの容易さで開発速度が出ます。" },
        { "role": "user", "text": "Supabase は?" },
        { "role": "assistant", "text": "セルフホスト時のロックイン回避を優先するなら自前 NextAuth + Postgres。Supabase 依存を消せば docker compose up だけで動く構成になります。" }
      ]
    },
    {
      "id": "arch-c1", "countryId": "architectura", "rank": "city",
      "label": "Prisma 7 schema", "position": [1080, 230], "urbanDensity": 5,
      "summary": "The data model: auth tables + ApiKey + full Atlas domain (Map / Country / City / Conversation / Message / Road / TerrainFeature / Artifact). N:N City↔Conversation from day 1 to dodge a Phase 4 schema break.",
      "messages": [
        { "role": "user", "text": "1会話=1街でいいか怪しい。後で論点分割を入れたい。" },
        { "role": "assistant", "text": "CityConversation を中間テーブルにして N:N にしました。Phase 2 は1行=1会話、Phase 4 で segmentStart/End を埋めれば論点分割が可能です。スキーマ破壊なし。" }
      ]
    },
    { "id": "arch-c2",  "countryId": "architectura", "rank": "city",    "label": "Auth.js v5",                               "position": [1190, 540], "urbanDensity": 4 },
    { "id": "arch-t1",  "countryId": "architectura", "rank": "town",    "label": "BYOK encryption",                          "position": [930, 480], "urbanDensity": 2 },

    {
      "id": "comm-cap", "countryId": "communitas", "rank": "capital",
      "label": "OSS launch", "labelJa": "公開", "position": [1010, 760], "urbanDensity": 6,
      "summary": "Day-1 public MIT repo on GitHub, Show HN + Product Hunt as the launch trigger. The differentiator is the terrain metaphor — easy to demo in a 30-second video.",
      "messages": [
        { "role": "user", "text": "ローンチで埋もれない自信ある?" },
        { "role": "assistant", "text": "個人開発OSSの99%は埋もれます。ただ、地形メタファーの独自性とスクショ映え、30秒で価値が伝わる点で当たる可能性は通常より高いです。当たらなくてもポートフォリオとして残ります。" }
      ]
    },
    { "id": "comm-c1",  "countryId": "communitas",   "rank": "city",    "label": "Show HN",                                  "position": [930, 880],  "urbanDensity": 3 },
    { "id": "comm-t1",  "countryId": "communitas",   "rank": "town",    "label": "MIT licensing",                            "position": [905, 600],  "urbanDensity": 1 },

    {
      "id": "imp-cap", "countryId": "importatio", "rank": "capital",
      "label": "Import", "labelJa": "取込", "position": [660, 800], "urbanDensity": 5,
      "summary": "The killer feature: drag-drop your ChatGPT / Claude / Claude Code export and watch a new continent grow. Without this, users have nothing to put on their map.",
      "messages": [
        { "role": "user", "text": "新規ユーザーが「自分の地図を見る」までの最短ルートは?" },
        { "role": "assistant", "text": "ChatGPT エクスポートをドラッグ→プレビュー→確認→地形化の4ステップ。Phase 2 はパース+保存だけで地形化は仮配置でOK。Phase 4 で本格地形化。" }
      ]
    },
    { "id": "imp-t1",   "countryId": "importatio",   "rank": "town",    "label": "ChatGPT parser",                           "position": [520, 720],  "urbanDensity": 2 },

    {
      "id": "vis-cap", "countryId": "visualizatio", "rank": "capital",
      "label": "Atlas engine", "labelJa": "地形エンジン", "position": [540, 470], "urbanDensity": 8,
      "summary": "The thing you're looking at right now: SVG-based map renderer with d3-zoom for pan/zoom, Catmull-Rom curves for organic roads and rivers, hill-shade filter for forest areas. This city is the meta-target of the entire project.",
      "messages": [
        { "role": "user", "text": "Canvas vs SVG どっちで描く?" },
        { "role": "assistant", "text": "初期はSVG。React DOM とインタラクション設計が楽で、ノード数千までは余裕です。スケール後に PixiJS への移行を検討。" },
        { "role": "user", "text": "古地図風にしたい" },
        { "role": "assistant", "text": "→ Google Maps 寄りに変更されました。" }
      ]
    },
    { "id": "vis-c1",   "countryId": "visualizatio", "rank": "city",    "label": "Pan / zoom",                               "position": [710, 490], "urbanDensity": 4 },
    { "id": "vis-c2",   "countryId": "visualizatio", "rank": "city",    "label": "Force layout",                             "position": [495, 320], "urbanDensity": 3 },
    { "id": "vis-t1",   "countryId": "visualizatio", "rank": "town",    "label": "Compass rose",                             "position": [445, 460], "urbanDensity": 1 }
  ],
