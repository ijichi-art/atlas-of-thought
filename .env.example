# ============================================================================
# Atlas of Thought — environment variables
# Copy to .env.local for development. NEVER commit .env / .env.local.
# ============================================================================

# --- Database (Postgres + pgvector) ---
# Local dev (brew postgresql@16): postgresql://USER@localhost:5432/atlas
# Docker compose:                  postgresql://atlas:atlas@localhost:5432/atlas
DATABASE_URL="postgresql://atlas:atlas@localhost:5432/atlas"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Public origin (used for share URLs and OGP) ---
# Set to your public domain in production, e.g. https://atlas.example.com
NEXT_PUBLIC_ORIGIN="http://localhost:3000"

# GitHub OAuth — create app at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- BYOK encryption ---
# Master key used to encrypt user-supplied Anthropic API keys (AES-256-GCM).
# Generate with: openssl rand -base64 32
# IMPORTANT: rotating this key invalidates all stored user API keys.
ENCRYPTION_KEY=""

# --- Optional: dev fallback Anthropic key (NOT used in production) ---
# Allows running terraform/chat without going through BYOK during dev.
# Leave blank in committed deployments.
ANTHROPIC_API_KEY_DEV_FALLBACK=""
